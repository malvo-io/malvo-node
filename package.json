{
  "name": "@malvo/server",
  "version": "0.2.0",
  "description": "Node.js/TypeScript server SDK for the Malvo API (Open Finance Brasil) — manage items, accounts, transactions, investments and webhooks, and mint connect tokens.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/malvo-io/malvo-node",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/malvo-io/malvo-node.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "malvo",
    "open-finance",
    "open-banking",
    "node",
    "server",
    "sdk",
    "fintech",
    "brasil"
  ]
}
